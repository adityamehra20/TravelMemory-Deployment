# Backend environment variables for TravelMemory
# Copy this file to `backend/.env` and fill in your real values.
# DO NOT commit the real .env file (it is git-ignored).

# MongoDB Atlas connection string
MONGO_URI='mongodb+srv://<username>:<password>@<cluster>.mongodb.net/travelmemory?retryWrites=true&w=majority'

# Port the Express backend listens on (assignment requires 3000)
PORT=3000
