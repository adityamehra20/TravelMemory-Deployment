# Frontend environment variables for TravelMemory
# Copy this file to `frontend/.env` and adjust for your setup.
# React only exposes variables prefixed with REACT_APP_ and bakes them in at build time,
# so you must re-run `npm run build` after changing this file.

# Recommended (Nginx Pattern A): same-origin, Nginx proxies /api -> backend:3000
REACT_APP_BACKEND_URL=/api

# Behind a custom domain with a dedicated API subdomain:
# REACT_APP_BACKEND_URL=https://api.your-domain.com

# Early testing directly against the EC2 instance:
# REACT_APP_BACKEND_URL=http://<EC2_PUBLIC_IP>:3000
